{
  "name": "json-lsp",
  "description": "JSON language server for schema validation and code intelligence",
  "version": "1.0.0",
  "author": {
    "name": "f5xc-salesdemos"
  },
  "lspServers": {
    "json": {
      "command": "vscode-json-language-server",
