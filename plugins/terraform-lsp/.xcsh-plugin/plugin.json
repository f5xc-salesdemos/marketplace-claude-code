{
  "name": "terraform-lsp",
  "description": "Terraform language server for infrastructure-as-code intelligence via terraform-ls",
  "version": "1.0.0",
  "author": {
    "name": "f5-sales-demo"
  },
  "lspServers": {
    "terraform-ls": {
      "command": "terraform-ls",
      "args": ["serve"],
      "extensionToLanguage": {
        ".tf": "terraform",
        ".tfvars": "terraform-vars"
      }
    }
  }
}
