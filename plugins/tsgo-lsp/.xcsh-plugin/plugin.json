{
  "name": "tsgo-lsp",
  "description": "TypeScript and JavaScript language server via tsgo (Microsoft's native TypeScript-Go port)",
  "version": "1.0.0",
  "author": {
    "name": "f5xc-salesdemos"
  },
  "lspServers": {
    "tsgo": {
      "command": "tsgo",
      "args": ["--lsp", "--stdio"],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".mts": "typescript",
        ".cts": "typescript",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    }
  }
}
